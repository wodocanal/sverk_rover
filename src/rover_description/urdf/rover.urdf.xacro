<?xml version="1.0"?>
<robot name="rover" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="wheel_radius" default="0.03"/>
  <xacro:arg name="wheel_width" default="0.03"/>
  <xacro:arg name="wheelbase" default="0.135"/>
  <xacro:arg name="track_width" default="0.195"/>
  <xacro:arg name="chassis_length" default="0.22"/>
  <xacro:arg name="chassis_width" default="0.20"/>
  <xacro:arg name="chassis_height" default="0.06"/>
  <xacro:arg name="imu_x" default="0.0"/>
  <xacro:arg name="imu_y" default="0.0"/>
  <xacro:arg name="imu_z" default="0.06"/>
  <xacro:arg name="imu_roll" default="0.0"/>
  <xacro:arg name="imu_pitch" default="0.0"/>
  <xacro:arg name="imu_yaw" default="0.0"/>
  <xacro:arg name="lidar_x" default="0.0"/>
  <xacro:arg name="lidar_y" default="0.0"/>
  <xacro:arg name="lidar_z" default="0.10"/>
  <xacro:arg name="lidar_roll" default="0.0"/>
  <xacro:arg name="lidar_pitch" default="0.0"/>
  <xacro:arg name="lidar_yaw" default="0.0"/>

  <xacro:property name="r" value="$(arg wheel_radius)"/>
  <xacro:property name="ww" value="$(arg wheel_width)"/>
  <xacro:property name="wb" value="$(arg wheelbase)"/>
  <xacro:property name="tw" value="$(arg track_width)"/>
  <xacro:property name="cl" value="$(arg chassis_length)"/>
  <xacro:property name="cw" value="$(arg chassis_width)"/>
  <xacro:property name="ch" value="$(arg chassis_height)"/>

  <link name="base_link">
    <visual>
      <geometry><box size="${cl} ${cw} ${ch}"/></geometry>
      <material name="dark"><color rgba="0.18 0.18 0.20 1"/></material>
    </visual>
    <collision><geometry><box size="${cl} ${cw} ${ch}"/></geometry></collision>
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.012" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.020"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="name x y axis_y">
    <link name="${name}_wheel_link">
      <visual>
        <origin rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${r}" length="${ww}"/></geometry>
        <material name="rubber"><color rgba="0.05 0.05 0.05 1"/></material>
      </visual>
      <collision>
        <origin rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${r}" length="${ww}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x} ${y} ${-ch/2}"/>
      <axis xyz="0 ${axis_y} 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left"  x="${ wb/2}" y="${ tw/2}" axis_y="1"/>
  <xacro:wheel name="front_right" x="${ wb/2}" y="${-tw/2}" axis_y="-1"/>
  <xacro:wheel name="rear_left"   x="${-wb/2}" y="${ tw/2}" axis_y="1"/>
  <xacro:wheel name="rear_right"  x="${-wb/2}" y="${-tw/2}" axis_y="-1"/>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.03 0.03 0.01"/></geometry>
      <material name="imu_blue"><color rgba="0.1 0.3 0.8 1"/></material>
    </visual>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="$(arg imu_x) $(arg imu_y) $(arg imu_z)"
            rpy="$(arg imu_roll) $(arg imu_pitch) $(arg imu_yaw)"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 -0.020"/>
      <geometry><cylinder radius="0.035" length="0.040"/></geometry>
      <material name="lidar_red"><color rgba="0.75 0.08 0.08 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.020"/>
      <geometry><cylinder radius="0.035" length="0.040"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.020"/>
      <mass value="0.17"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00010"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z)"
            rpy="$(arg lidar_roll) $(arg lidar_pitch) $(arg lidar_yaw)"/>
  </joint>
</robot>
