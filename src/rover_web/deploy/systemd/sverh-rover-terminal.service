[Unit]
Description=Sverh Rover web terminal
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/sverk_rover
ExecStart=/usr/bin/ttyd -i 127.0.0.1 -p 7681 -W -b /terminal -m 8 -w %h/sverk_rover /bin/bash %h/sverk_rover/src/rover_web/tools/rover_web_shell.sh %h/sverk_rover
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
