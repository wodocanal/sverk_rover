python3 - <<'PY'
from pathlib import Path

path = Path.home() / "ros2_gosha_ws/src/rover_bringup/web/assets/app.js"
text = path.read_text(encoding="utf-8")

old = """const sessionId = sessionStorage.getItem('sverhSessionId') || crypto.randomUUID();"""

new = """function createSessionId() {
  if (globalThis.crypto && typeof globalThis.crypto.randomUUID === 'function') {
    return globalThis.crypto.randomUUID();
  }
  return `sverh-${Date.now()}-${Math.random().toString(36).slice(2)}`;
}

const sessionId = sessionStorage.getItem('sverhSessionId') || createSessionId();"""

if old not in text:
    raise SystemExit("Исходная строка не найдена: возможно, исправление уже применено")

path.write_text(text.replace(old, new), encoding="utf-8")
print(f"Исправлен файл: {path}")
PY

