python3 - <<'PY'
import time

import rclpy
from geometry_msgs.msg import Twist
from rclpy.node import Node

TEST_SPEED = 0.15
TEST_DURATION = 5.0

rclpy.init()
node = Node("controlled_drive_test")
publisher = node.create_publisher(Twist, "/cmd_vel", 10)

stop = Twist()
forward = Twist()
forward.linear.x = TEST_SPEED

def publish_for(message, duration):
    end = time.monotonic() + duration

    while time.monotonic() < end:
        publisher.publish(message)
        rclpy.spin_once(node, timeout_sec=0.0)
        time.sleep(0.02)

try:
    print("Установка соединения...")
    publish_for(stop, 1.0)

    print(
        f"Движение {TEST_DURATION} секунд "
        f"со скоростью {TEST_SPEED} м/с"
    )
    publish_for(forward, TEST_DURATION)

    print("Контролируемая остановка...")
    publish_for(stop, 1.5)

finally:
    publish_for(stop, 0.5)
    node.destroy_node()
    rclpy.shutdown()
PY

