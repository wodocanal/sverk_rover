python3 - <<'PY'
from pathlib import Path
import shutil

path = (
    Path.home()
    / "ros2_gosha_ws"
    / "src"
    / "rover_bringup"
    / "rover_bringup"
    / "web_gateway_node.py"
)

backup = path.with_name("web_gateway_node.py.bak_diagnostic_level")
old = '"level": int(status.level),'
new = '''"level": (
                        int(status.level[0])
                        if isinstance(status.level, (bytes, bytearray, memoryview))
                        and len(status.level) > 0
                        else int(status.level)
                    ),'''

text = path.read_text(encoding="utf-8")
count = text.count(old)

print(f"Найдено исходных строк: {count}")

if count == 1:
    shutil.copy2(path, backup)
    path.write_text(text.replace(old, new), encoding="utf-8")
    print(f"Исправлен файл: {path}")
    print(f"Резервная копия: {backup}")
elif count == 0 and "isinstance(status.level" in text:
    print("Исправление уже применено.")
else:
    raise SystemExit(
        f"Ожидалось ровно одно вхождение, найдено: {count}. "
        "Файл не изменён."
    )
PY

