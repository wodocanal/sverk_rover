python3 - <<'PY'
import math

import rclpy
from rclpy.node import Node
from sensor_msgs.msg import LaserScan


def normalize_degrees(angle):
    return (angle + 180.0) % 360.0 - 180.0


def angular_difference(a, b):
    return abs(normalize_degrees(a - b))


class ScanDirectionCheck(Node):
    def __init__(self):
        super().__init__('scan_direction_check')
        self.subscription = self.create_subscription(
            LaserScan,
            '/scan',
            self.on_scan,
            10,
        )

    def on_scan(self, msg):
        sectors = {
            'ВПЕРЁД   (0°)': 0.0,
            'ВЛЕВО  (+90°)': 90.0,
            'НАЗАД  (180°)': 180.0,
            'ВПРАВО (-90°)': -90.0,
        }

        results = {}

        for name, center in sectors.items():
            values = []

            for index, distance in enumerate(msg.ranges):
                if not math.isfinite(distance):
                    continue

                if distance < msg.range_min or distance > msg.range_max:
                    continue

                angle = math.degrees(
                    msg.angle_min + index * msg.angle_increment
                )
                angle = normalize_degrees(angle)

                if angular_difference(angle, center) <= 15.0:
                    values.append(distance)

            results[name] = min(values) if values else None

        print('\nРасстояния по секторам:')
        for name, distance in results.items():
            if distance is None:
                print(f'  {name}: нет измерения')
            else:
                print(f'  {name}: {distance:.3f} м')

        valid = {
            name: distance
            for name, distance in results.items()
            if distance is not None
        }

        if valid:
            nearest = min(valid, key=valid.get)
            print(f'\nБлижайший сектор: {nearest}')

        rclpy.shutdown()


rclpy.init()
node = ScanDirectionCheck()

while rclpy.ok():
    rclpy.spin_once(node, timeout_sec=1.0)

node.destroy_node()
PY

