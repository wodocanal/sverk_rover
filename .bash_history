from pathlib import Path

path = Path.home() / "ros2_ws/src/rover_bringup/launch/robot.launch.py"

text = path.read_text(encoding="utf-8")

text = text.replace(
    "from launch.actions import DeclareLaunchArgument, EmitEvent, "
    "LogError, LogInfo, OpaqueFunction",
    "from launch.actions import DeclareLaunchArgument, EmitEvent, "
    "LogInfo, OpaqueFunction",
)

text = text.replace(
    "LogError(msg=f'Hardware discovery failed: {exc}'),",
    "LogInfo(msg=f'[ERROR] Hardware discovery failed: {exc}'),",
)

path.write_text(text, encoding="utf-8")

print(f"Исправлен файл: {path}")
PY

