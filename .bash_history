python3 - <<'PY'
from pathlib import Path

path = (
    Path.home()
    / "ros2_gosha_ws"
    / "src"
    / "rover_bringup"
    / "rover_bringup"
    / "web_gateway_node.py"
)

text = path.read_text(encoding="utf-8")
count = text.count("self._clients")

print(f"Найдено вхождений self._clients: {count}")

if count == 0:
    print("Исправление уже применено.")
elif count == 5:
    text = text.replace("self._clients", "self._web_clients")
    path.write_text(text, encoding="utf-8")
    print(f"Исправлен файл: {path}")
else:
    raise SystemExit(
        f"Неожиданное количество вхождений: {count}. "
        "Файл не изменён."
    )
PY

