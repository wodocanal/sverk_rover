import json
import urllib.request

with urllib.request.urlopen(
    "http://127.0.0.1:8765/api/status",
    timeout=3,
) as response:
    data = json.load(response)

for name in ("odom", "wheel_odometry", "imu", "diagnostics"):
    state = data["topics"][name]
    print(
        f"{name:18s} "
        f"messages={state['message_count']} "
        f"age_sec={state['age_sec']}"
    )

print("imu_payload =", data.get("imu"))
PY

sudo systemctl stop sverh-rover-web-gateway
python3 - <<'PY'
from pathlib import Path
import shutil

path = (
    Path.home()
    / "ros2_gosha_ws"
    / "src"
    / "rover_bringup"
    / "rover_bringup"
    / "web_gateway_node.py"
)

backup = path.with_name("web_gateway_node.py.bak_imu_qos")
text = path.read_text(encoding="utf-8")

import_anchor = "from rclpy.node import Node\n"
import_line = "from rclpy.qos import qos_profile_sensor_data\n"

old_subscription = """        self.create_subscription(
            Imu,
            str(self.get_parameter("imu_topic").value),
            self._imu_callback,
            50,
        )
"""

new_subscription = """        self.create_subscription(
            Imu,
            str(self.get_parameter("imu_topic").value),
            self._imu_callback,
            qos_profile_sensor_data,
        )
"""

changed = False

if import_line not in text:
    if import_anchor not in text:
        raise SystemExit("Не найдена строка импорта rclpy.node")
    text = text.replace(
        import_anchor,
        import_anchor + import_line,
        1,
    )
    changed = True

if old_subscription in text:
    text = text.replace(
        old_subscription,
        new_subscription,
        1,
    )
    changed = True
elif new_subscription not in text:
    raise SystemExit("Не найдена ожидаемая подписка IMU")

if changed:
    shutil.copy2(path, backup)
    path.write_text(text, encoding="utf-8")
    print(f"Исправлен файл: {path}")
    print(f"Резервная копия: {backup}")
else:
    print("Исправление QoS уже применено")
PY

